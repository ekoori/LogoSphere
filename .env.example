# ============================================================================
# LogoSphere — example environment configuration
# Copy to `.env` and adjust. Never commit your real `.env`.
# ============================================================================

# ---- Backend (Flask) -------------------------------------------------------

# Cassandra contact point(s). Comma-separated for a multi-node cluster.
# Local dev (Podman/Docker single node):
CASSANDRA_HOST=127.0.0.1

# Flask session-signing secret. MUST be set to a long random value in
# production. Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Send the session cookie only over HTTPS. Keep false for local HTTP dev;
# set true in production (behind TLS).
SESSION_COOKIE_SECURE=false

# Port the Flask backend listens on (used by the run scripts; default 5000).
PORT=5000

# ---- Frontend (Create React App) -------------------------------------------
# These belong in `frontend/.env` (CRA only exposes vars prefixed REACT_APP_).
#
# In local dev you do NOT need this: the dev server proxies /api to the backend
# (see "proxy" in frontend/package.json), keeping the session cookie first-party.
# Set it ONLY for production builds, to the backend's absolute URL:
#
# REACT_APP_API_URL=https://api.your-domain.example

# ---- Tests -----------------------------------------------------------------
# Base URL the integration tests target (backend/app/tests/test_trusttrail_api.py).
LOGOSPHERE_API_URL=http://localhost:5000/api
